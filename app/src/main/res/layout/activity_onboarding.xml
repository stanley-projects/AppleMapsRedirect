<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bridge_background"
    android:paddingHorizontal="24dp"
    android:paddingTop="72dp"
    android:paddingBottom="32dp">

    <!-- Hero -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_bridge_mark"
        android:contentDescription="@string/app_name"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textColor="@color/bridge_ink"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="-0.01" />

    <!-- Upper spacer pushes features into the visual middle -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Feature row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_feature_link"
            android:contentDescription="@null"
            android:layout_marginEnd="20dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/onboarding_feature_link"
            android:textSize="15sp"
            android:textColor="@color/bridge_ink"
            android:lineSpacingMultiplier="1.3" />
    </LinearLayout>

    <!-- Feature row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_feature_route"
            android:contentDescription="@null"
            android:layout_marginEnd="20dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/onboarding_feature_route"
            android:textSize="15sp"
            android:textColor="@color/bridge_ink"
            android:lineSpacingMultiplier="1.3" />
    </LinearLayout>

    <!-- Feature row 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_feature_open"
            android:contentDescription="@null"
            android:layout_marginEnd="20dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/onboarding_feature_open"
            android:textSize="15sp"
            android:textColor="@color/bridge_ink"
            android:lineSpacingMultiplier="1.3" />
    </LinearLayout>

    <!-- Lower spacer pushes CTA to the bottom -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_enable"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="52dp"
        android:text="@string/onboarding_btn_enable"
        android:textSize="15sp"
        android:textColor="@color/bridge_on_ink"
        android:letterSpacing="0"
        android:textAllCaps="false"
        android:fontFamily="sans-serif-medium"
        app:backgroundTint="@color/bridge_ink"
        app:cornerRadius="12dp"
        app:rippleColor="@color/bridge_on_ink"
        android:stateListAnimator="@null"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_skip"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/onboarding_btn_skip"
        android:textSize="14sp"
        android:textAllCaps="false"
        android:textColor="@color/bridge_ink_muted"
        android:fontFamily="sans-serif-medium"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:rippleColor="@color/bridge_divider" />

</LinearLayout>
